    "Buscar Histórico da Conversa": {
      "main": [[{ "node": "Montar Contexto para IA", "type": "main", "index": 0 }]]
    },
    "Montar Contexto para IA": {
      "main": [[{ "node": "Claude Haiku — Gerar Resposta", "type": "main", "index": 0 }]]
